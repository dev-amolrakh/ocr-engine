# OCR Service — Local Windows Testing Configuration

# App
APP_NAME=ocr-service
DEBUG=true
LOG_LEVEL=INFO

# MongoDB (local installation)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ocr_db

# Redis (local installation)
REDIS_URL=redis://localhost:6379
REDIS_STREAM_MAX_LEN=100000

# Local Storage (relative to ocr_service folder)
NFS_BASE_PATH=./storage
NFS_INCOMING_PATH=./storage/incoming
NFS_PROCESSED_PATH=./storage/processed
NFS_FAILED_PATH=./storage/failed
NFS_ARCHIVE_PATH=./storage/archive

# Ollama (LLM fallback for unknown documents)
OLLAMA_BASE_URL=http://localhost:11434
QWEN_VL_MODEL=qwen2.5:1.5b
EXTRACTION_MODEL=qwen2.5:1.5b

# PaddleOCR (CPU mode for local testing)
PADDLE_LANG=en
PADDLE_USE_GPU=false
PADDLE_CONFIDENCE_THRESHOLD=0.75
PADDLE_DET_DB_THRESH=0.3
PADDLE_DET_DB_BOX_THRESH=0.5

# Worker tuning (reduced for local testing)
OCR_BATCH_SIZE=4
QWEN_VL_BATCH_SIZE=2
TRANSLATION_BATCH_SIZE=4
RENDER_BATCH_SIZE=5
WORKER_CONCURRENCY=2
MAX_QUEUE_DEPTH=1000

# ML Models
INDICTRANS2_MODEL_PATH=./models/indictrans2
FASTTEXT_MODEL_PATH=./models/fasttext/lid.176.bin

# Image preprocessing
PREPROCESS_TARGET_DPI=300
PREPROCESS_HANDWRITING_MODE=true
PREPROCESS_SAVE_INTERMEDIATE=false

# Upload limits
MAX_UPLOAD_SIZE_MB=500
MAX_BULK_FILES=50
