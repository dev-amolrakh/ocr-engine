# OCR Service Configuration
# Copy this file to .env and adjust values as needed

# App
APP_NAME=ocr-service
DEBUG=false
LOG_LEVEL=INFO

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ocr_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_STREAM_MAX_LEN=100000

# Local Storage (adjust paths for your OS)
NFS_BASE_PATH=./storage
NFS_INCOMING_PATH=./storage/incoming
NFS_PROCESSED_PATH=./storage/processed
NFS_FAILED_PATH=./storage/failed
NFS_ARCHIVE_PATH=./storage/archive

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
QWEN_VL_MODEL=qwen2.5vl:7b
EXTRACTION_MODEL=qwen2.5:14b

# PaddleOCR
PADDLE_LANG=en
PADDLE_USE_GPU=true
PADDLE_CONFIDENCE_THRESHOLD=0.75
PADDLE_DET_DB_THRESH=0.3
PADDLE_DET_DB_BOX_THRESH=0.5

# Worker tuning
OCR_BATCH_SIZE=16
QWEN_VL_BATCH_SIZE=4
TRANSLATION_BATCH_SIZE=16
RENDER_BATCH_SIZE=10
WORKER_CONCURRENCY=4
MAX_QUEUE_DEPTH=10000

# ML Models
INDICTRANS2_MODEL_PATH=./models/indictrans2
FASTTEXT_MODEL_PATH=./models/fasttext/lid.176.bin

# Image preprocessing
PREPROCESS_TARGET_DPI=300
PREPROCESS_HANDWRITING_MODE=true
PREPROCESS_SAVE_INTERMEDIATE=false

# Upload limits
MAX_UPLOAD_SIZE_MB=500
MAX_BULK_FILES=50
